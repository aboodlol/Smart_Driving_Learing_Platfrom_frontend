{
  "version": "2.0.0",
  "tasks": [
    // ─── Angular / Frontend ───────────────────────────────────────────────────
    {
      "label": "ng: serve",
      "type": "shell",
      "command": "ng serve",
      "group": "build",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building...",
          "endsPattern": "Compiled successfully|Failed to compile"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "ng: build (production)",
      "type": "shell",
      "command": "ng build --configuration production",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "ng: build (qa)",
      "type": "shell",
      "command": "ng build --configuration qa",
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "ng: test (coverage)",
      "type": "shell",
      "command": "ng test --watch=false --code-coverage",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "ng: test (watch)",
      "type": "shell",
      "command": "ng test",
      "group": "test",
      "isBackground": true,
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "ng: lint",
      "type": "shell",
      "command": "ng lint",
      "group": "test",
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "always" }
    },
    // ─── npm ─────────────────────────────────────────────────────────────────
    {
      "label": "npm: install",
      "type": "shell",
      "command": "npm install",
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "npm: audit",
      "type": "shell",
      "command": "npm audit",
      "group": "test",
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    {
      "label": "npm: audit fix",
      "type": "shell",
      "command": "npm audit fix",
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    },
    // ─── .NET / Backend ───────────────────────────────────────────────────────
    {
      "label": "dotnet: build (API)",
      "type": "shell",
      "command": "dotnet build",
      "options": { "cwd": "C:\\TFS\\Daleel-API" },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "dotnet: test (API)",
      "type": "shell",
      "command": "dotnet test --logger \"console;verbosity=detailed\"",
      "options": { "cwd": "C:\\TFS\\Daleel-API" },
      "group": "test",
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "dotnet: restore (API)",
      "type": "shell",
      "command": "dotnet restore",
      "options": { "cwd": "C:\\TFS\\Daleel-API" },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "dotnet: clean (API)",
      "type": "shell",
      "command": "dotnet clean",
      "options": { "cwd": "C:\\TFS\\Daleel-API" },
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always" }
    },
    // ─── Full stack ───────────────────────────────────────────────────────────
    {
      "label": "full-stack: build (frontend + backend)",
      "dependsOn": ["ng: build (production)", "dotnet: build (API)"],
      "dependsOrder": "parallel",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "full-stack: test (frontend + backend)",
      "dependsOn": ["ng: test (coverage)", "dotnet: test (API)"],
      "dependsOrder": "parallel",
      "group": "test",
      "problemMatcher": []
    }
  ]
}
